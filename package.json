{
  "name": "dark-notes",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@stripe/react-stripe-js": "^1.3.0",
    "@stripe/stripe-js": "^1.13.0",
    "@testing-library/jest-dom": "^5.11.4",
    "@testing-library/react": "^11.1.0",
    "@testing-library/user-event": "^12.1.10",
    "add": "^2.0.6",
    "aws-amplify": "^3.3.7",
    "node-sass": "4.14.1",
    "node-sass-chokidar": "^1.5.0",
    "react": "^17.0.1",
    "react-bootstrap": "^1.4.0",
    "react-dom": "^17.0.1",
    "react-icons": "^3.11.0",
    "react-router-bootstrap": "^0.25.0",
    "react-router-dom": "^5.2.0",
    "react-scripts": "4.0.3",
    "tailwindcss": "^2.0.3",
    "web-vitals": "^0.2.4",
    "yarn": "^1.22.10"
  },
  "scripts": {
    "build-css": "node-sass-chokidar --include-path ./src --include-path ./node_modules src/ -o src/",
    "watch-css": "npm run build-css && node-sass-chokidar --include-path ./src --include-path ./node_modules src/ -o src/ --watch --recursive",
    "build-tailwind:css": "postcss src/assets/tailwind.css -o src/assets/main.css",
    "watch-tailwind:css": "postcss src/assets/tailwind.css -o src/assets/main.css",
    "build": "react-scripts build",
    "start-js": "react-scripts start",
    "start": "react-scripts start",
    "build-js": "react-scripts build",
    "test": "react-scripts test --env=jsdom",
    "eject": "react-scripts eject",
    "start-with-css": "npm run watch-tailwind:css && react-scripts start",
    "deploy": "yarn build && aws s3 sync build/ s3://dark-notes"
  },
  "devDependencies": {
    "autoprefixer": "^10.0.2",
    "axios": "^0.18.1",
    "husky": ">=4",
    "lint-staged": ">=10",
    "postcss": "^8.3.5",
    "postcss-nested": "^5.0.5",
    "prettier": "2.2.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,css,md}": "prettier --write"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
